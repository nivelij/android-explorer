        android:fillColor="#F2C85A"
        android:pathData="M22,40 h59 a5,5 0 0 1 5,5 v34 a5,5 0 0 1 -5,5 h-54 a5,5 0 0 1 -5,-5 z" />
    <!-- Tab (darker gold), top-left, stepping down to the body on its right. -->
